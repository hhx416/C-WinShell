// 显示进程列表
int lsh_ps(char **args) {
    system("start cmd /k \"tasklist & pause\"");
    return 1;
}

// 切换语言
int lsh_lang(char **args) {
    if (args[1] == NULL) {
        AppendOutput(get_msg("Current language: English\n", "当前语言: 中文\n"));
    } else if (strcmp(args[1], "en") == 0 || strcmp(args[1], "english") == 0) {
        language = 0;
        // 保存语言到文件
        FILE *f = fopen("language.txt", "w");
        if (f) {
            fprintf(f, "%d\n", language);
            fclose(f);
        }
        AppendOutput("Switched to English\n");
    } else if (strcmp(args[1], "zh") == 0 || strcmp(args[1], "chinese") == 0) {
        language = 1;
        // 保存语言到文件
        FILE *f = fopen("language.txt", "w");
        if (f) {
            fprintf(f, "%d\n", language);
            fclose(f);
        }
        AppendOutput("Switched to Chinese\n");
    } else {
        AppendOutput(get_msg("Invalid language. Use 'en' or 'zh'\n", "无效语言。使用 'en' 或 'zh'\n"));
    }
    return 1;
}

// 设置背景图片
int lsh_bg(char **args) {
    if (args[1] == NULL) {
        if (background_image) {
            char buf[256];
            sprintf(buf, get_msg("Current background: %s\n", "当前背景: %s\n"), background_image);
            AppendOutput(buf);
        } else {
            AppendOutput(get_msg("No background set\n", "未设置背景\n"));
        }
    } else {
        FILE *file = fopen(args[1], "r");
        if (file) {
            fclose(file);
            if (strstr(args[1], ".bmp") || strstr(args[1], ".BMP")) {
                background_image = strdup(args[1]);
                LoadBackgroundImage(background_image);
                // 保存背景到文件
                FILE *f = fopen("background.txt", "w");
                if (f) {
                    fprintf(f, "%s\n", background_image);
                    fclose(f);
                }
                char buf[256];
                sprintf(buf, get_msg("Background set to: %s\n", "背景设置为: %s\n"), background_image);
                AppendOutput(buf);
                InvalidateRect(hwndMain, NULL, TRUE);
            } else {
                AppendOutput(get_msg("Invalid file type. Only BMP files are supported.\n", "无效文件类型。只支持BMP文件。\n"));
            }
        } else {
            char buf[256];
            sprintf(buf, get_msg("File not found: %s\n", "文件未找到: %s\n"), args[1]);
            AppendOutput(buf);
        }
    }
    return 1;
}

// 执行命令
int lsh_execute(char **args) {
    if (args[0] == NULL) { return 1; }
    for (int i = 0; i < lsh_num_builtins(); i++) {
        if (strcmp(args[0], builtin_str[i]) == 0 || strcmp(args[0], builtin_str_cn[i]) == 0) { 
            return (*builtin_func[i])(args); 
        }
    }
    print_ascii_art();
    printf(get_msg("Command not found: %s\n", "命令未找到: %s\n"), args[0]);
    return 1;
}

// 主循环（控制台版本）
void lsh_loop(void) {
    char *line; char **args; int status;
    do {
        printf("> ");
        line = lsh_read_line();
        args = lsh_split_line(line);
        status = lsh_execute(args);
        free(line);
        for (int i = 0; args[i] != NULL; i++) { free(args[i]); }
        free(args);
    } while (status);
}

// 窗口过程函数，处理GUI消息
LRESULT CALLBACK WndProc(HWND hwnd, UINT msg, WPARAM wParam, LPARAM lParam) {
    switch (msg) {
        case WM_PAINT: {  // 绘制消息
            PAINTSTRUCT ps;
            HDC hdc = BeginPaint(hwnd, &ps);
            RECT rect;
            GetClientRect(hwnd, &rect);
            DrawBackground(hdc, &rect);  // 绘制背景
            // 选择字体
            HFONT oldFont = (HFONT)SelectObject(hdc, hFont);
            // 绘制文本
            SetBkMode(hdc, TRANSPARENT);
            SetTextColor(hdc, RGB(0, 0, 255));
            // 创建显示缓冲区，包含输出和当前输入
            char displayBuffer[4096 + 256];
            strcpy(displayBuffer, outputBuffer);
            strcat(displayBuffer, "> ");
            strcat(displayBuffer, inputBuffer);
            // 转换到Unicode并绘制
            int wlen = MultiByteToWideChar(CP_UTF8, 0, displayBuffer, -1, NULL, 0);
            WCHAR *wbuf = (WCHAR*)malloc(wlen * sizeof(WCHAR));
            MultiByteToWideChar(CP_UTF8, 0, displayBuffer, -1, wbuf, wlen);
            // 计算文本高度并设置滚动条
            RECT calcRect = rect;
            DrawTextW(hdc, wbuf, -1, &calcRect, DT_LEFT | DT_TOP | DT_WORDBREAK | DT_CALCRECT);
            int textHeight = calcRect.bottom - calcRect.top;
            SCROLLINFO si;
            si.cbSize = sizeof(SCROLLINFO);
            si.fMask = SIF_RANGE | SIF_PAGE | SIF_POS;
            si.nMin = 0;
            si.nMax = textHeight > rect.bottom ? textHeight - rect.bottom : 0;
            si.nPage = rect.bottom;
            si.nPos = scrollPos;
            SetScrollInfo(hwnd, SB_VERT, &si, TRUE);
            ShowScrollBar(hwnd, SB_VERT, si.nMax > 0);
            maxScroll = si.nMax;  // 更新最大滚动位置
            // 绘制文本，考虑滚动
            RECT drawRect = rect;
            drawRect.top -= scrollPos;
            DrawTextW(hdc, wbuf, -1, &drawRect, DT_LEFT | DT_TOP | DT_WORDBREAK);
            free(wbuf);
            // 恢复字体
            SelectObject(hdc, oldFont);
            EndPaint(hwnd, &ps);
            break;
        }
        case WM_CHAR: {  // 字符输入消息
            if (wParam == VK_RETURN) {  // 回车键
                AppendOutput("\n");
                ProcessCommand(inputBuffer);  // 处理命令
                inputBuffer[0] = '\0';  // 清空输入缓冲区
                InvalidateRect(hwnd, NULL, TRUE);  // 重绘窗口
            } else if (wParam == VK_BACK) {  // 退格键
                int len = strlen(inputBuffer);
                if (len > 0) inputBuffer[len - 1] = 0;
            } else {  // 其他字符
                char ch = (char)wParam;
                char tmp[2] = { ch, '\0' };
                strncat(inputBuffer, tmp, 1);
            }
            InvalidateRect(hwnd, NULL, TRUE);
            break;
        }
        case WM_VSCROLL: {  // 垂直滚动消息
            int oldPos = scrollPos;
            int newPos = oldPos;
            switch (LOWORD(wParam)) {
                case SB_LINEUP: newPos -= 50; break;
                case SB_LINEDOWN: newPos += 50; break;
                case SB_PAGEUP: newPos -= 300; break;  // 假设页面大小约300像素
                case SB_PAGEDOWN: newPos += 300; break;
                case SB_THUMBTRACK: newPos = HIWORD(wParam); break;
            }
            newPos = max(0, min(newPos, maxScroll));
            if (newPos != oldPos) {
                scrollPos = newPos;
                SetScrollPos(hwnd, SB_VERT, newPos, TRUE);
                InvalidateRect(hwnd, NULL, TRUE);
                SetFocus(hwnd);  // 确保窗口保持焦点
            }
            break;
        }
        case WM_MOUSEWHEEL: {  // 鼠标滚轮消息
            int delta = GET_WHEEL_DELTA_WPARAM(wParam);
            int newPos = scrollPos - (delta / WHEEL_DELTA) * 50;
            newPos = max(0, min(newPos, maxScroll));
            if (newPos != scrollPos) {
                scrollPos = newPos;
                SetScrollPos(hwnd, SB_VERT, newPos, TRUE);
                InvalidateRect(hwnd, NULL, TRUE);
                SetFocus(hwnd);  // 确保窗口保持焦点
            }
            break;
        }
        case WM_DESTROY:  // 窗口销毁消息
            // 清理资源
            if (hFont) DeleteObject(hFont);
            if (hBackground) DeleteObject(hBackground);
            PostQuitMessage(0);  // 发送退出消息
            break;
        default:
            return DefWindowProc(hwnd, msg, wParam, lParam);
    }
    return 0;
}

// 加载背景图片
void LoadBackgroundImage(const char *path) {
    if (hBackground) {
        DeleteObject(hBackground);
        hBackground = NULL;
    }
    hBackground = (HBITMAP)LoadImage(NULL, path, IMAGE_BITMAP, 0, 0, LR_LOADFROMFILE);
}

// 绘制背景
void DrawBackground(HDC hdc, RECT *rect) {
    if (hBackground) {  // 如果有背景图片
        HDC hdcMem = CreateCompatibleDC(hdc);
        HBITMAP hOld = (HBITMAP)SelectObject(hdcMem, hBackground);
        BITMAP bm;
        GetObject(hBackground, sizeof(BITMAP), &bm);
        StretchBlt(hdc, 0, 0, rect->right, rect->bottom, hdcMem, 0, 0, bm.bmWidth, bm.bmHeight, SRCCOPY);
        SelectObject(hdcMem, hOld);
        DeleteDC(hdcMem);
    } else {  // 默认背景
        FillRect(hdc, rect, (HBRUSH)(COLOR_WINDOW + 1));
    }
}

// 添加输出文本到缓冲区
void AppendOutput(const char *text) {
    strncat(outputBuffer, text, sizeof(outputBuffer) - strlen(outputBuffer) - 1);
}

// 处理用户输入的命令
void ProcessCommand(const char *cmd) {
    char **args = lsh_split_line((char*)cmd);  // 分割命令
    if (args[0] == NULL) return;
    int found = 0;
    for (int i = 0; i < lsh_num_builtins(); i++) {
        if (strcmp(args[0], builtin_str[i]) == 0 || strcmp(args[0], builtin_str_cn[i]) == 0) {
            // 执行内置命令
            (*builtin_func[i])(args);
            found = 1;
            break;
        }
    }
    if (!found) {
        char buf[256];
        sprintf(buf, get_msg("Command not found: %s\n", "命令未找到: %s\n"), args[0]);
        AppendOutput(buf);
    }
    AppendOutput("> ");  // 添加提示符
    // 释放内存
    for (int i = 0; args[i] != NULL; i++) free(args[i]);
    free(args);
}
